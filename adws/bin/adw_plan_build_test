#!/usr/bin/env ruby
# frozen_string_literal: true

#
# ADW Plan, Build & Test - AI Developer Workflow (ADW)
#
# Usage: adw_plan_build_test <github-issue-number> [adw-id]
#
# Ejecuta el pipeline completo encadenando:
# 1. adw_plan_build - Planificación e implementación
# 2. Fase de testing con resolución automática de fallos
# 3. Commit y creación de PR
#
# Si los tests fallan tras MAX_TEST_RETRY_ATTEMPTS intentos de resolución,
# el pipeline se detiene con estado "error" sin llegar a commit ni PR.
#

require "bundler/setup"
require_relative "../lib/adw"

# Constantes de agentes
AGENT_TESTER = "test_runner"

# Máximo de reintentos de tests tras resolución
MAX_TEST_RETRY_ATTEMPTS = 4

def parse_args
  if ARGV.length < 1
    puts "Usage: adw_plan_build_test <issue-number> [adw-id]"
    puts "Example: adw_plan_build_test 123"
    puts "Example: adw_plan_build_test 123 abc12345"
    exit 1
  end

  issue_number = ARGV[0]
  adw_id = ARGV[1]

  [issue_number, adw_id]
end

def format_issue_message(adw_id, agent_name, message, session_id = nil)
  if session_id
    "#{adw_id}_#{agent_name}_#{session_id}: #{message}"
  else
    "#{adw_id}_#{agent_name}: #{message}"
  end
end

# --- Funciones de testing ---

def run_tests(issue_number, adw_id, logger)
  log_dir = File.join(Adw.project_root, ".issues", issue_number.to_s, "logs", adw_id, AGENT_TESTER)

  request = Adw::AgentTemplateRequest.new(
    agent_name: AGENT_TESTER,
    slash_command: "/adw:test",
    args: [log_dir],
    issue_number: issue_number,
    adw_id: adw_id,
    model: "sonnet"
  )

  logger.debug("test_template_request: #{request.to_h}")

  response = Adw::Agent.execute_template(request)

  logger.debug("test_response: #{response.to_h}")

  response
end

def parse_test_results(output, logger)
  json_text = output.strip

  # Extraer JSON si viene envuelto en markdown (```json ... ```)
  if json_text =~ /```(?:json)?\s*\n?(.*?)\n?\s*```/m
    json_text = $1.strip
  end

  results_data = JSON.parse(json_text)
  results = results_data.map { |r| Adw::TestResult.new(r) }

  passed_count = results.count(&:passed)
  failed_count = results.length - passed_count

  [results, passed_count, failed_count]
rescue JSON::ParserError, Dry::Struct::Error => e
  logger.error("Error parseando resultados de tests: #{e}")
  [[], 0, 0]
end

def resolve_failed_tests(failed_tests, adw_id, issue_number, logger, iteration: 1)
  resolved_count = 0
  unresolved_count = 0

  failed_tests.each_with_index do |test, idx|
    logger.info("\n=== Resolviendo test fallido #{idx + 1}/#{failed_tests.length}: #{test.test_name} ===")

    test_payload = JSON.generate(test.to_h)
    agent_name = "test_resolver_iter#{iteration}_#{idx}"

    resolve_request = Adw::AgentTemplateRequest.new(
      agent_name: agent_name,
      slash_command: "/adw:resolve_failed_test",
      args: [test_payload],
      issue_number: issue_number,
      adw_id: adw_id,
      model: "sonnet"
    )

    # Publicar en la issue
    Adw::GitHub.create_issue_comment(
      issue_number,
      format_issue_message(
        adw_id, agent_name,
        "Intentando resolver: #{test.test_name}\n```json\n#{test_payload}\n```"
      )
    )

    response = Adw::Agent.execute_template(resolve_request)

    if response.success
      resolved_count += 1
      Adw::GitHub.create_issue_comment(
        issue_number,
        format_issue_message(adw_id, agent_name, "Resuelto correctamente: #{test.test_name}")
      )
      logger.info("Resuelto correctamente: #{test.test_name}")
    else
      unresolved_count += 1
      Adw::GitHub.create_issue_comment(
        issue_number,
        format_issue_message(adw_id, agent_name, "No se pudo resolver: #{test.test_name}")
      )
      logger.error("No se pudo resolver: #{test.test_name}")
    end
  end

  [resolved_count, unresolved_count]
end

def run_tests_with_resolution(adw_id, issue_number, logger)
  attempt = 0
  results = []
  passed_count = 0
  failed_count = 0

  while attempt < MAX_TEST_RETRY_ATTEMPTS
    attempt += 1
    logger.info("\n=== Ejecución de tests - Intento #{attempt}/#{MAX_TEST_RETRY_ATTEMPTS} ===")

    test_response = run_tests(issue_number, adw_id, logger)

    unless test_response.success
      logger.error("Error ejecutando tests: #{test_response.output}")
      Adw::GitHub.create_issue_comment(
        issue_number,
        format_issue_message(adw_id, AGENT_TESTER, "Error ejecutando tests: #{test_response.output}")
      )
      break
    end

    results, passed_count, failed_count = parse_test_results(test_response.output, logger)

    # Si no hay fallos o es el último intento, terminamos
    if failed_count == 0
      logger.info("Todos los tests pasaron correctamente")
      break
    end

    if attempt == MAX_TEST_RETRY_ATTEMPTS
      logger.info("Alcanzado el máximo de intentos (#{MAX_TEST_RETRY_ATTEMPTS})")
      break
    end

    # Intentar resolver los tests fallidos
    logger.info("\n=== Intentando resolver tests fallidos ===")
    Adw::GitHub.create_issue_comment(
      issue_number,
      format_issue_message(adw_id, "ops", "Encontrados #{failed_count} tests fallidos. Intentando resolución...")
    )

    failed_tests = results.reject(&:passed)
    resolved, _unresolved = resolve_failed_tests(failed_tests, adw_id, issue_number, logger, iteration: attempt)

    if resolved > 0
      Adw::GitHub.create_issue_comment(
        issue_number,
        format_issue_message(adw_id, "ops", "Resueltos #{resolved}/#{failed_count} tests fallidos")
      )
      logger.info("\n=== Re-ejecutando tests tras resolver #{resolved} tests ===")
    else
      logger.info("Ningún test fue resuelto, parando reintentos")
      break
    end
  end

  if attempt == MAX_TEST_RETRY_ATTEMPTS && failed_count > 0
    logger.warn("Alcanzado máximo de reintentos (#{MAX_TEST_RETRY_ATTEMPTS}) con #{failed_count} fallos pendientes")
    Adw::GitHub.create_issue_comment(
      issue_number,
      format_issue_message(adw_id, "ops", "Alcanzado máximo de reintentos (#{MAX_TEST_RETRY_ATTEMPTS}) con #{failed_count} fallos")
    )
  end

  [results, passed_count, failed_count]
end

def format_test_results_comment(results, passed_count, failed_count)
  return "No se encontraron resultados de tests" if results.empty?

  failed_tests = results.reject(&:passed)
  passed_tests = results.select(&:passed)

  parts = []

  if failed_tests.any?
    parts << ""
    parts << "## Tests Fallidos"
    parts << ""
    failed_tests.each do |test|
      parts << "### #{test.test_name}"
      parts << ""
      parts << "```json"
      parts << JSON.pretty_generate(test.to_h)
      parts << "```"
      parts << ""
    end
  end

  if passed_tests.any?
    parts << "## Tests Superados"
    parts << ""
    passed_tests.each do |test|
      parts << "### #{test.test_name}"
      parts << ""
      parts << "```json"
      parts << JSON.pretty_generate(test.to_h)
      parts << "```"
      parts << ""
    end
  end

  parts.pop if parts.last == ""
  parts.join("\n")
end

def log_test_results(issue_number, adw_id, results, logger)
  passed_count = results.count(&:passed)
  failed_count = results.length - passed_count

  summary = "## Resumen de Tests\n\n"
  summary += "**Total:** #{results.length}\n"
  summary += "**Pasados:** #{passed_count}\n"
  summary += "**Fallidos:** #{failed_count}\n\n"

  if results.any?
    summary += "### Detalle:\n"
    results.each do |result|
      status = result.passed ? "PASS" : "FAIL"
      summary += "- #{status} **#{result.test_name}**\n"
      summary += "  - Error: #{result.error[0..200]}...\n" if !result.passed && result.error
    end
  end

  if failed_count > 0
    summary += "\n### Estado General: FALLIDO\n"
    summary += "Fallos totales: #{failed_count}\n"
  else
    summary += "\n### Estado General: PASADO\n"
    summary += "Todos los #{results.length} tests pasaron correctamente.\n"
  end

  Adw::GitHub.create_issue_comment(
    issue_number,
    format_issue_message(adw_id, "test_summary", summary)
  )

  logger.info("Resumen de resultados de tests publicado en issue ##{issue_number}")
end

# --- Workflow principal ---

def main
  issue_number, adw_id = parse_args

  # Generar ADW ID si no se proporcionó
  adw_id ||= Adw::Utils.make_adw_id

  # Configurar logger
  logger = Adw::Utils.setup_logger(issue_number, adw_id, "adw_plan_build_test")
  logger.info("ADW Plan Build Test - ID: #{adw_id}")

  # Paso 1: Ejecutar adw_plan_build (plan + implementación)
  script_dir = File.dirname(File.expand_path(__FILE__))
  plan_build_script = File.join(script_dir, "adw_plan_build")

  logger.info("Ejecutando adw_plan_build...")
  plan_build_pid = Process.spawn(
    RbConfig.ruby, plan_build_script, issue_number, adw_id,
    out: $stdout,
    err: $stderr
  )
  _, plan_build_status = Process.wait2(plan_build_pid)

  unless plan_build_status.success?
    logger.error("adw_plan_build falló con código #{plan_build_status.exitstatus}")
    exit 1
  end

  logger.info("adw_plan_build completado correctamente")

  # Paso 2: Fase de testing
  # Cargar el tracker existente
  tracker = Adw::Tracker.load(issue_number) || {}
  tracker[:adw_id] = adw_id

  Adw::Tracker.update(tracker, issue_number, "testing", logger)
  logger.info("\n=== Ejecutando suite de tests ===")
  Adw::GitHub.create_issue_comment(
    issue_number,
    format_issue_message(adw_id, AGENT_TESTER, "Ejecutando tests de la aplicación...")
  )

  results, passed_count, failed_count = run_tests_with_resolution(adw_id, issue_number, logger)

  # Publicar resultados
  results_comment = format_test_results_comment(results, passed_count, failed_count)
  Adw::GitHub.create_issue_comment(
    issue_number,
    format_issue_message(adw_id, AGENT_TESTER, "Resultados finales de tests:\n#{results_comment}")
  )
  log_test_results(issue_number, adw_id, results, logger)

  logger.info("Resultados de tests: #{passed_count} pasados, #{failed_count} fallidos")

  # Si los tests fallan, parar el pipeline
  if failed_count > 0
    logger.error("Tests fallidos: #{failed_count} fallos pendientes")
    Adw::Tracker.update(tracker, issue_number, "error", logger)
    exit 1
  end

  # Paso 3: Commit y PR (los tests pasaron)
  # adw_plan_build ya hizo commit y PR, así que solo necesitamos
  # hacer commit de los posibles cambios del test resolver y actualizar el PR

  # Comprobar si hay cambios pendientes del test resolver
  stdout, _, status = Open3.capture3("git", "status", "--porcelain")
  if status.success? && !stdout.strip.empty?
    logger.info("Hay cambios del test resolver, haciendo commit...")

    commit_agent_name = "#{AGENT_TESTER}_committer"
    commit_request = Adw::AgentTemplateRequest.new(
      agent_name: commit_agent_name,
      slash_command: "/git:commit",
      args: ["-m", "\"test: correcciones de tests para ##{issue_number}\""],
      issue_number: issue_number,
      adw_id: adw_id,
      model: "sonnet"
    )

    commit_response = Adw::Agent.execute_template(commit_request)

    if commit_response.success
      logger.info("Commit de correcciones de tests creado")

      # Push de los cambios
      _, stderr, push_status = Open3.capture3("git", "push")
      if push_status.success?
        logger.info("Cambios de tests pusheados correctamente")
      else
        logger.warn("Warning: No se pudieron pushear los cambios de tests: #{stderr}")
      end
    else
      logger.warn("Warning: No se pudo hacer commit de correcciones de tests: #{commit_response.output}")
    end
  end

  Adw::Tracker.update(tracker, issue_number, "done", logger)
  logger.info("ADW Plan Build Test completado correctamente para issue ##{issue_number}")
end

main
