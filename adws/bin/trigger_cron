#!/usr/bin/env ruby
# frozen_string_literal: true

#
# Cron-based ADW trigger system that monitors GitHub issues and automatically processes them.
#
# This script polls GitHub every 20 seconds to detect:
# 1. New issues without comments → full pipeline
# 2. Issues where the latest comment contains 'adw' → full pipeline
# 3. Issues with adw/done label and new human comment → patch workflow
#
# When a qualifying issue is found, it triggers the appropriate workflow script.
#
# Usage: ./trigger_cron
#

require "bundler/setup"
require "rufus-scheduler"
require "set"
require_relative "../lib/adw"

module Adw
  module Pipelines
    class TriggerCron
      RESET = "\e[0m"

      attr_reader :repo_path, :processed_issues, :issue_last_comment
      attr_accessor :shutdown_requested

      def initialize(repo_path)
        @repo_path = repo_path
        @processed_issues = Set.new
        @issue_last_comment = {}
        @shutdown_requested = false
        @stdout_mutex = Mutex.new
      end

      def hsl_to_rgb(h, s, l)
        c = (1 - (2 * l - 1).abs) * s
        x = c * (1 - ((h / 60.0) % 2 - 1).abs)
        m = l - c / 2.0
        r1, g1, b1 = case (h / 60).to_i
                     when 0 then [c, x, 0]
                     when 1 then [x, c, 0]
                     when 2 then [0, c, x]
                     when 3 then [0, x, c]
                     when 4 then [x, 0, c]
                     else        [c, 0, x]
                     end
        [((r1 + m) * 255).round, ((g1 + m) * 255).round, ((b1 + m) * 255).round]
      end

      def color_for(issue_number)
        return "" unless $stdout.tty?
        hue = (issue_number.to_i * 137.508) % 360
        r, g, b = hsl_to_rgb(hue, 0.85, 0.55)
        "\e[38;2;#{r};#{g};#{b}m"
      end

      def reset_seq
        $stdout.tty? ? RESET : ""
      end

      def clog(issue_number, msg)
        @stdout_mutex.synchronize do
          $stdout.puts "#{color_for(issue_number)}#{msg}#{reset_seq}"
          $stdout.flush
        end
      end

      def cwarn(issue_number, msg)
        @stdout_mutex.synchronize do
          $stderr.puts "#{color_for(issue_number)}#{msg}#{reset_seq}"
          $stderr.flush
        end
      end

      def glog(msg)
        @stdout_mutex.synchronize do
          $stdout.puts msg
          $stdout.flush
        end
      end

      def spawn_with_color(issue_number, *cmd, **opts)
        color = color_for(issue_number)
        rst   = reset_seq
        read_io, write_io = IO.pipe

        pid = Process.spawn(*cmd, out: write_io, err: write_io, **opts)
        write_io.close
        Process.detach(pid)

        Thread.new do
          begin
            read_io.each_line do |line|
              @stdout_mutex.synchronize do
                $stdout.print "#{color}#{line}#{rst}"
                $stdout.flush
              end
            end
          ensure
            read_io.close
          end
        end

        pid
      end

      def should_process_issue?(issue_number)
        comments = Adw::GitHub.fetch_issue_comments(repo_path, issue_number)

        # If no comments, it's a new issue - process it
        if comments.empty?
          clog(issue_number, "INFO: Issue ##{issue_number} has no comments - marking for processing")
          return true
        end

        # Get the latest comment
        latest_comment = comments.last
        comment_body = latest_comment.fetch("body", "").downcase.strip
        comment_id = latest_comment.fetch("id", nil)

        # Check if we've already processed this comment
        last_processed = issue_last_comment[issue_number]
        return false if last_processed == comment_id

        # Check if latest comment is exactly 'adw'
        if comment_body == "adw"
          clog(issue_number, "INFO: Issue ##{issue_number} - latest comment is 'adw' - marking for processing")
          issue_last_comment[issue_number] = comment_id
          return true
        end

        false
      end

      def check_patch_trigger(issue_number)
        comments = Adw::GitHub.fetch_issue_comments(repo_path, issue_number)
        return nil if comments.empty?

        latest = comments.last
        comment_body = latest.fetch("body", "")
        comment_id = latest.fetch("id", nil)

        # Skip if we already processed this comment
        return nil if issue_last_comment[issue_number] == comment_id

        # Skip bot comments
        return nil if Adw::PipelineHelpers.bot_comment?(comment_body)

        # Skip tracker comments
        return nil if comment_body.include?(Adw::Tracker::COMMENT_MARKER)

        # New human comment on a done issue → trigger patch
        clog(issue_number, "INFO: Issue ##{issue_number} (adw/done) - new human comment detected")
        issue_last_comment[issue_number] = comment_id

        # Return the human comment body directly (avoids a second API call)
        comment_body
      end

      def trigger_patch_workflow(issue_number, comment_body)
        script_path = File.join(__dir__, "adw_patch")

        clog(issue_number, "INFO: Triggering ADW patch workflow for issue ##{issue_number}")

        # Run patch in the worktree if it exists
        wt_path = File.join(Adw.project_root, "trees", "issue-#{issue_number}")
        spawn_opts = {}
        cmd = [RbConfig.ruby, script_path, issue_number.to_s, comment_body]

        if Dir.exist?(wt_path)
          clog(issue_number, "INFO: Running patch in worktree: #{wt_path}")
          env = { "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR" => "false" }
          cmd.unshift(env)
          spawn_opts[:chdir] = wt_path
        end

        pid = spawn_with_color(issue_number, *cmd, **spawn_opts)

        clog(issue_number, "INFO: Successfully triggered patch workflow for issue ##{issue_number} (PID: #{pid})")
        true
      rescue => e
        cwarn(issue_number, "ERROR: Exception while triggering patch workflow for issue ##{issue_number}: #{e}")
        false
      end

      def trigger_worktree_teardown(branch_name, issue_num = nil)
        script_path = File.join(__dir__, "adw_teardown_worktree")
        log_num = issue_num || 0
        clog(log_num, "INFO: Triggering worktree teardown for branch: #{branch_name}")
        pid = if issue_num
          spawn_with_color(issue_num, RbConfig.ruby, script_path, branch_name)
        else
          p = Process.spawn(RbConfig.ruby, script_path, branch_name, out: $stdout, err: $stderr)
          Process.detach(p)
          p
        end
        clog(log_num, "INFO: Teardown spawned for #{branch_name} (PID: #{pid})")
        true
      rescue => e
        cwarn(log_num, "ERROR: Exception triggering teardown for #{branch_name}: #{e}")
        false
      end

      def cleanup_stale_worktrees(open_issue_numbers)
        trees_dir = File.join(Adw.project_root, "trees")
        return unless Dir.exist?(trees_dir)

        Dir.entries(trees_dir).reject { |e| e.start_with?(".") }.each do |branch_name|
          # Branch format: issue-ISSUE_NUM
          parts = branch_name.split("-")
          next if parts.length < 2

          issue_num = parts[1].to_i
          next if issue_num == 0
          next if open_issue_numbers.include?(issue_num)

          clog(issue_num, "INFO: Issue ##{issue_num} closed — removing worktree: #{branch_name}")
          trigger_worktree_teardown(branch_name, issue_num)
        end
      end

      def trigger_workflow(issue_number)
        script_path = File.join(__dir__, "adw_full_pipeline")

        clog(issue_number, "INFO: Triggering ADW workflow for issue ##{issue_number}")

        pid = spawn_with_color(issue_number, RbConfig.ruby, script_path, issue_number.to_s)

        clog(issue_number, "INFO: Successfully triggered workflow for issue ##{issue_number} (PID: #{pid})")
        true
      rescue => e
        cwarn(issue_number, "ERROR: Exception while triggering workflow for issue ##{issue_number}: #{e}")
        false
      end

      def check_and_process_issues
        return if shutdown_requested

        start_time = Time.now
        glog("INFO: Starting issue check cycle")

        begin
          # Fetch all open issues
          issues = Adw::GitHub.fetch_open_issues(repo_path)

          if issues.empty?
            glog("INFO: No open issues found")
            return
          end

          # Track newly qualified issues
          new_qualifying_issues = []
          patch_comments = {}

          # Check each issue
          issues.each do |issue|
            issue_number = issue.number
            next unless issue_number

            adw_labels = issue.labels.select { |l| l.name.start_with?("adw/") }

            # Case 1: Issue with adw/done → check for new human comment to trigger patch
            # NOTE: Must be checked BEFORE processed_issues filter, since the issue may have
            # been processed in this session (full pipeline) but now needs a patch.
            if adw_labels.any? { |l| l.name == "adw/done" }
              comment_body = check_patch_trigger(issue_number)
              if comment_body
                patch_comments[issue_number] = comment_body
              end
              next
            end

            # For full pipeline only: skip issues already processed in this session
            next if processed_issues.include?(issue_number)

            # Case 2: Issue with other adw/ labels (not error) → skip (in progress)
            if adw_labels.any?
              non_error_labels = adw_labels.reject { |l| l.name == "adw/error" }
              if non_error_labels.any?
                clog(issue_number, "INFO: Skipping issue ##{issue_number} - ADW active (#{non_error_labels.map(&:name).join(', ')})")
                next
              end
            end

            # Case 3: Issue without adw labels or with adw/error → full pipeline
            if should_process_issue?(issue_number)
              new_qualifying_issues << issue_number
            end
          end

          # Process patch issues
          if patch_comments.any?
            glog("INFO: Found #{patch_comments.length} issues needing patch: #{patch_comments.keys}")

            patch_comments.each do |issue_number, comment_body|
              break if shutdown_requested

              unless trigger_patch_workflow(issue_number, comment_body)
                clog(issue_number, "WARNING: Failed to trigger patch for issue ##{issue_number}, will retry in next cycle")
              end
            end
          end

          # Process full pipeline issues
          if new_qualifying_issues.any?
            glog("INFO: Found #{new_qualifying_issues.length} new qualifying issues: #{new_qualifying_issues}")

            new_qualifying_issues.each do |issue_number|
              break if shutdown_requested

              if trigger_workflow(issue_number)
                processed_issues.add(issue_number)
              else
                clog(issue_number, "WARNING: Failed to process issue ##{issue_number}, will retry in next cycle")
              end
            end
          end

          if new_qualifying_issues.empty? && patch_comments.empty?
            glog("INFO: No new qualifying issues found")
          end

          cleanup_stale_worktrees(issues.map(&:number).to_set)

          cycle_time = Time.now - start_time
          glog("INFO: Check cycle completed in #{cycle_time.round(2)} seconds")
          glog("INFO: Total processed issues in session: #{processed_issues.length}")
        rescue => e
          warn "ERROR: Error during check cycle: #{e}"
          warn e.backtrace.join("\n")
        end
      end
    end
  end
end

if __FILE__ == $0
  # Get repository URL from git remote
  begin
    github_repo_url = Adw::GitHub.repo_url
    repo_path = Adw::GitHub.extract_repo_path(github_repo_url)
  rescue => e
    warn "ERROR: #{e}"
    exit 1
  end

  cron = Adw::Pipelines::TriggerCron.new(repo_path)

  # Graceful shutdown flag
  Signal.trap("INT") do
    puts "\nINFO: Received SIGINT, initiating graceful shutdown..."
    cron.shutdown_requested = true
  end

  Signal.trap("TERM") do
    puts "\nINFO: Received SIGTERM, initiating graceful shutdown..."
    cron.shutdown_requested = true
  end

  # Main entry point
  if ARGV.include?("--help") || ARGV.include?("-h")
    puts <<~HELP
      Cron-based ADW trigger system that monitors GitHub issues and automatically processes them.

      Usage: ./trigger_cron

      Environment variables:
        GITHUB_PAT - (Optional) GitHub Personal Access Token

      The script will poll GitHub issues every 20 seconds and trigger
      the ADW workflow for qualifying issues. It also detects human comments
      on issues with adw/done label and triggers the patch workflow.

      Note: Repository URL is automatically detected from git remote.
    HELP
    exit 0
  end

  puts "INFO: Starting ADW cron trigger"
  puts "INFO: Repository: #{repo_path}"
  puts "INFO: Polling interval: 20 seconds"

  scheduler = Rufus::Scheduler.new

  scheduler.every "20s" do
    cron.check_and_process_issues
  end

  # Run initial check immediately
  cron.check_and_process_issues

  # Main loop
  puts "INFO: Entering main scheduling loop"
  loop do
    break if cron.shutdown_requested

    sleep 1
  end

  scheduler.shutdown
  puts "INFO: Shutdown complete"
end
