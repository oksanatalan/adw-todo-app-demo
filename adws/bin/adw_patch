#!/usr/bin/env ruby
# frozen_string_literal: true

#
# ADW Patch - AI Developer Workflow (ADW)
#
# Usage: adw_patch <github-issue-number> <comment-body> [adw-id]
#
# Entry point for human validation post-pipeline.
# When a human comments on an issue with adw/done, this script:
# 1. Classifies the comment (patch or none)
# 2. If patch: creates a focused patch plan
# 3. Implements the patch
# 4. Runs tests with automatic resolution
# 5. Runs technical code review with auto-fix
# 6. Runs visual review with screenshot evidence
# 7. Generates documentation
# 8. Commits and pushes changes
# 9. Returns issue to adw/done state
#

require "bundler/setup"
require_relative "../lib/adw"

if ARGV.length < 2
  puts "Usage: adw_patch <issue-number> <comment-body> [adw-id]"
  puts "Example: adw_patch 123 \"Change the button color to red\""
  puts "Example: adw_patch 123 \"Missing email validation\" abc12345"
  exit 1
end

issue_number = ARGV[0]
comment_body = ARGV[1]
adw_id = ARGV[2] || Adw::Utils.make_adw_id

# Enter worktree if it exists (makes this script self-contained like adw_full_pipeline).
# When spawned by trigger_cron with chdir, Dir.pwd is already the worktree and this is a no-op
# (trees/issue-N doesn't exist inside the worktree itself).
worktree_path = File.join(Dir.pwd, "trees", "issue-#{issue_number}")
if Dir.exist?(worktree_path)
  Dir.chdir(worktree_path)
  ENV["CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR"] = "false"
end

logger = Adw::Utils.setup_logger(issue_number, adw_id, "adw_patch")
logger.info("ADW Patch - ID: #{adw_id}")
logger.info("Issue: ##{issue_number}")
logger.info("Comment: #{comment_body[0..100]}")

result = Adw::Workflows::Patch.result(
  issue_number: issue_number,
  adw_id: adw_id,
  logger: logger,
  comment_body: comment_body
)

if result.success?
  if result.comment_classification != "patch"
    logger.info("Comment does not require a patch (#{result.comment_classification}). Exiting successfully.")
  else
    logger.info("ADW patch completed for issue ##{issue_number}")
  end
  exit 0
else
  logger.error("Patch workflow failed: #{result.error}")
  exit 1
end
