#!/usr/bin/env bash
set -euo pipefail

# Usage: worktree/isolate <worktree_path>
# Calculates deterministic ports from branch name, writes .env.local.
# Outputs JSON with port assignments to stdout.

WORKTREE_PATH="$(realpath "${1:?Usage: worktree/isolate <worktree_path>}")"

# Copy shared adws/.env from main repo
MAIN_REPO="$(cd "$(dirname "$0")/../../.." && pwd)"
if [[ -f "${MAIN_REPO}/adws/.env" ]]; then
  mkdir -p "${WORKTREE_PATH}/adws"
  cp "${MAIN_REPO}/adws/.env" "${WORKTREE_PATH}/adws/.env"
  echo "Copied ${MAIN_REPO}/adws/.env → ${WORKTREE_PATH}/adws/.env" >&2
fi

# Derive branch name from git
BRANCH_NAME="$(git -C "${WORKTREE_PATH}" rev-parse --abbrev-ref HEAD)"

# Deterministic port calculation (SHA256-based)
HASH=$(echo -n "${BRANCH_NAME}" | openssl dgst -sha256 | awk '{print $NF}' | head -c 8)
OFFSET=$(( 16#${HASH} % 900 ))
POSTGRES_PORT=$(( 5400 + OFFSET ))
BACKEND_PORT=$(( 8000 + OFFSET ))
FRONTEND_PORT=$(( 9000 + OFFSET ))
COMPOSE_PROJECT="adw-$(echo "${BRANCH_NAME}" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9-]/-/g' | cut -c1-63)"
DATABASE_URL="postgresql://postgres:password@localhost:${POSTGRES_PORT}/app_development"

# Write .env.local
cat > "${WORKTREE_PATH}/.env.local" <<ENVEOF
# Worktree: ${BRANCH_NAME}
# Generated automatically by ADW -- DO NOT EDIT
COMPOSE_PROJECT_NAME=${COMPOSE_PROJECT}
POSTGRES_PORT=${POSTGRES_PORT}
DATABASE_URL=${DATABASE_URL}
PORT=${BACKEND_PORT}
VITE_PORT=${FRONTEND_PORT}
VITE_API_BASE_URL=http://localhost:${BACKEND_PORT}
ENVEOF

echo "Wrote ${WORKTREE_PATH}/.env.local" >&2

# Output JSON for callers to parse
echo "{\"postgres_port\":${POSTGRES_PORT},\"backend_port\":${BACKEND_PORT},\"frontend_port\":${FRONTEND_PORT},\"compose_project\":\"${COMPOSE_PROJECT}\"}"
