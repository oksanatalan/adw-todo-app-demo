#!/usr/bin/env ruby
# frozen_string_literal: true

#
# ADW Full Pipeline - AI Developer Workflow (ADW)
#
# Usage: adw_full_pipeline <github-issue-number> [adw-id]
#
# Ejecuta el pipeline completo encadenando:
# 1. adw_plan_build - Clasificacion, planificacion e implementacion
# 2. Fase de testing con resolucion automatica de fallos
# 3. Fase de review tecnica con auto-fix de problemas criticos
# 4. Fase de review contra la issue con evidencia visual (screenshots + R2)
# 5. Fase de documentacion (generacion de docs en app_docs/)
# 6. Commit y creacion de PR
#
# Si los tests fallan tras MAX_TEST_RETRY_ATTEMPTS intentos de resolucion,
# o la review encuentra problemas criticos irresolubles,
# el pipeline se detiene con estado "error" sin llegar a commit ni PR.
#

require "bundler/setup"
require_relative "../lib/adw"

include Adw::PipelineHelpers

# Constantes de agentes
AGENT_TESTER = "test_runner"
AGENT_REVIEWER_TECH = "code_reviewer"
AGENT_REVIEWER_ISSUE = "issue_reviewer"
AGENT_DOCUMENTER = "documentation_generator"
AGENT_PR_CREATOR = "pr_creator"

# Maximo de reintentos
MAX_REVIEW_FIX_ATTEMPTS = 2

def parse_args
  if ARGV.length < 1
    puts "Usage: adw_full_pipeline <issue-number> [adw-id]"
    puts "Example: adw_full_pipeline 123"
    puts "Example: adw_full_pipeline 123 abc12345"
    exit 1
  end

  issue_number = ARGV[0]
  adw_id = ARGV[1]

  [issue_number, adw_id]
end

def load_issue(issue_number)
  repo_path = Adw::GitHub.extract_repo_path(Adw::GitHub.repo_url)
  Adw::GitHub.fetch_issue(issue_number, repo_path)
end

# --- Funciones de testing ---

def log_test_results(issue_number, adw_id, results, passed_count, failed_count, logger)
  parts = []

  if failed_count > 0
    parts << "❌ **#{passed_count} passed** | **#{failed_count} failed**"
  else
    parts << "✅ **#{passed_count} passed**"
  end
  parts << ""

  results.each do |result|
    emoji = result.passed ? "✅" : "❌"
    line = "- #{emoji} #{result.test_name}"
    line += " — `#{result.error[0..100]}`" if !result.passed && result.error
    parts << line
  end

  Adw::GitHub.create_issue_comment(
    issue_number,
    format_issue_message(adw_id, "test_summary", parts.join("\n"))
  )

  logger.info("Test results posted to issue ##{issue_number}")
end

# --- Funciones de review ---

def run_review(adw_id, issue_number, issue, tracker, logger)
  plan_path = Adw::PipelineHelpers.plan_path_for(issue_number)

  request = Adw::AgentTemplateRequest.new(
    agent_name: AGENT_REVIEWER_TECH,
    slash_command: "/adw:review:tech",
    args: [issue.to_json, plan_path],
    adw_id: adw_id,
    model: "sonnet"
  )

  logger.info("Ejecutando revision tecnica de codigo...")
  response = Adw::Agent.execute_template(request)

  unless response.success
    logger.error("Error ejecutando review: #{response.output}")
    return { overall_severity: "error", action_required: "none" }
  end

  # Parsear resultados del review
  review_result = parse_review_results(response.output, logger)

  # Publicar resultados como comentario en la issue
  review_comment = format_review_comment(review_result)
  Adw::GitHub.create_issue_comment(
    issue_number,
    format_issue_message(adw_id, AGENT_REVIEWER_TECH, review_comment)
  )

  # Manejar hallazgos criticos con loop de auto-fix
  if review_result[:action_required] == "fix_and_rerun"
    review_result = handle_review_fixes(review_result, adw_id, issue_number, issue, plan_path, logger)
  end

  review_result
end

def parse_review_results(output, logger)
  json_text = Adw::PipelineHelpers.extract_json_from_markdown(output)

  data = JSON.parse(json_text)
  {
    overall_severity: data["overall_severity"],
    summary: data["summary"],
    checks: data["checks"] || [],
    action_required: data["action_required"] || "none",
    fix_suggestions: data["fix_suggestions"] || []
  }
rescue JSON::ParserError => e
  logger.error("Error parseando resultados de review: #{e}")
  { overall_severity: "warning", summary: "No se pudieron parsear los resultados de la revision",
    checks: [], action_required: "none", fix_suggestions: [] }
end

def format_review_comment(review_result)
  parts = []
  parts << "## Resultados de Revision de Codigo"
  parts << ""
  parts << "**Severidad general:** #{review_result[:overall_severity]}"
  parts << "**Resumen:** #{review_result[:summary]}"
  parts << ""

  if review_result[:checks]&.any?
    parts << "| Criterio | Resultado | Severidad | Detalles |"
    parts << "|----------|-----------|-----------|----------|"
    review_result[:checks].each do |check|
      emoji = check["result"] == "PASS" ? "✅" : "❌"
      parts << "| #{check['name']} | #{emoji} #{check['result']} | #{check['severity']} | #{check['details']} |"
    end
  end

  if review_result[:fix_suggestions]&.any?
    parts << ""
    parts << "### Sugerencias de correccion"
    review_result[:fix_suggestions].each do |s|
      parts << "- #{s}"
    end
  end

  parts.join("\n")
end

def handle_review_fixes(review_result, adw_id, issue_number, issue, plan_path, logger)
  attempt = 0

  while attempt < MAX_REVIEW_FIX_ATTEMPTS && review_result[:action_required] == "fix_and_rerun"
    attempt += 1
    logger.info("Review fix - intento #{attempt}/#{MAX_REVIEW_FIX_ATTEMPTS}")

    # Preparar payload con los problemas a corregir
    fix_payload = JSON.generate({
      fix_suggestions: review_result[:fix_suggestions],
      failed_checks: review_result[:checks]&.select { |c| c["result"] == "FAIL" }
    })

    agent_name = "review_resolver_iter#{attempt}"
    fix_request = Adw::AgentTemplateRequest.new(
      agent_name: agent_name,
      slash_command: "/adw:resolve_review_issue",
      args: [fix_payload],
      adw_id: adw_id,
      model: "sonnet"
    )

    fix_response = Adw::Agent.execute_template(fix_request)

    unless fix_response.success
      logger.warn("Review fix intento #{attempt} fallo: #{fix_response.output}")
      break
    end

    # Re-ejecutar review para verificar correcciones
    logger.info("Re-ejecutando review tras correcciones...")
    recheck_request = Adw::AgentTemplateRequest.new(
      agent_name: "#{AGENT_REVIEWER_TECH}_recheck_#{attempt}",
      slash_command: "/adw:review:tech",
      args: [issue.to_json, plan_path],
      adw_id: adw_id,
      model: "sonnet"
    )

    recheck_response = Adw::Agent.execute_template(recheck_request)

    if recheck_response.success
      review_result = parse_review_results(recheck_response.output, logger)

      review_comment = format_review_comment(review_result)
      Adw::GitHub.create_issue_comment(
        issue_number,
        format_issue_message(adw_id, AGENT_REVIEWER_TECH, "Revision post-correccion (intento #{attempt}):\n#{review_comment}")
      )
    else
      logger.warn("Error en re-review: #{recheck_response.output}")
      break
    end
  end

  review_result
end

# --- Funciones de review:issue (evidencia visual) ---

def run_issue_review(adw_id, issue_number, issue, tracker, logger)
  plan_path = Adw::PipelineHelpers.plan_path_for(issue_number)

  request = Adw::AgentTemplateRequest.new(
    agent_name: AGENT_REVIEWER_ISSUE,
    slash_command: "/adw:review:issue",
    args: [issue.to_json, plan_path],
    adw_id: adw_id,
    model: "sonnet"
  )

  logger.info("Ejecutando revision contra la issue...")
  response = Adw::Agent.execute_template(request)

  unless response.success
    logger.warn("Warning: Revision de issue fallo: #{response.output}")
    Adw::GitHub.create_issue_comment(
      issue_number,
      format_issue_message(adw_id, AGENT_REVIEWER_ISSUE,
        "Advertencia: No se pudo completar la revision visual: #{response.output}")
    )
    return nil
  end

  # Parsear resultados
  result = parse_issue_review_results(response.output, logger)

  unless result[:success] && result[:screenshots]&.any?
    logger.warn("No se obtuvieron screenshots")
    return result
  end

  # Subir screenshots a R2
  begin
    result[:screenshots] = Adw::R2.upload_evidence(
      adw_id, result[:screenshots], logger
    )
    link_screenshot_urls(result[:screenshots], result[:review_issues])
  rescue Aws::S3::Errors::ServiceError, Errno::ENOENT => e
    logger.warn("Error subiendo screenshots a R2: #{e.message}")
    result[:errors] ||= []
    result[:errors] << "R2 upload failed: #{e.message}"
  end

  # Publicar comentario de evidencia
  evidence_comment = format_evidence_comment(result)
  Adw::GitHub.create_issue_comment(
    issue_number,
    format_issue_message(adw_id, AGENT_REVIEWER_ISSUE, evidence_comment)
  )

  logger.info("Evidencia visual publicada en issue ##{issue_number}")
  result
end

# --- Funciones de documentacion ---

def run_documentation(adw_id, issue_number, tracker, logger)
  plan_path = Adw::PipelineHelpers.plan_path_for(issue_number)

  request = Adw::AgentTemplateRequest.new(
    agent_name: AGENT_DOCUMENTER,
    slash_command: "/adw:document",
    args: [adw_id, plan_path],
    adw_id: adw_id,
    model: "sonnet"
  )

  logger.info("Ejecutando generacion de documentacion...")
  response = Adw::Agent.execute_template(request)

  unless response.success
    logger.warn("Warning: Generacion de documentacion fallo: #{response.output}")
    return # No bloqueante: documentacion no para el pipeline
  end

  doc_path = response.output.strip
  logger.info("Documentacion generada: #{doc_path}")
  post_documentation_summary(issue_number, adw_id, doc_path, logger)
end

def post_documentation_summary(issue_number, adw_id, doc_path, logger)
  content = File.read(doc_path)

  parts = []
  parts << "## Documentation Updated"
  parts << ""
  parts << "`#{doc_path}`"
  parts << ""

  if content =~ /## Overview\s*\n(.*?)(?=\n## )/m
    parts << "### Overview"
    parts << ""
    parts << $1.strip
    parts << ""
  end

  if content =~ /## Que se Construyo\s*\n(.*?)(?=\n## )/m
    parts << "### Changes"
    parts << ""
    parts << $1.strip
  end

  Adw::GitHub.create_issue_comment(
    issue_number,
    format_issue_message(adw_id, AGENT_DOCUMENTER, parts.join("\n"))
  )
  logger.info("Documentation summary posted to issue ##{issue_number}")
rescue => e
  logger.warn("Warning: Could not post documentation summary: #{e.message}")
end

# --- Funciones de commit y PR ---

def commit_all_changes(issue, tracker, adw_id, issue_number, logger)
  # Comprobar si hay cambios pendientes
  stdout, _, status = Open3.capture3("git", "status", "--porcelain")
  if status.success? && stdout.strip.empty?
    logger.info("No hay cambios pendientes para commit")
    return
  end

  issue_class = tracker[:classification] || "/chore"
  issue_type = issue_class.delete_prefix("/")

  commit_request = Adw::AgentTemplateRequest.new(
    agent_name: "pipeline_committer",
    slash_command: "/git:commit",
    args: ["-m", "\"#{issue_type}: implement, test, review and document ##{issue.number}\""],
    adw_id: adw_id,
    model: "sonnet"
  )

  response = Adw::Agent.execute_template(commit_request)
  check_error(response, issue_number, "Error committing changes", logger, tracker)
  logger.info("Todos los cambios commiteados")
end

def create_pull_request(tracker, issue, adw_id, issue_number, logger)
  branch_name = tracker[:branch_name]

  request = Adw::AgentTemplateRequest.new(
    agent_name: AGENT_PR_CREATOR,
    slash_command: "/adw:pull_request",
    args: [branch_name, issue.to_json, adw_id],
    adw_id: adw_id,
    model: "sonnet"
  )

  response = Adw::Agent.execute_template(request)
  check_error(response, issue_number, "Error creating pull request", logger, tracker)

  pr_url = response.output.strip
  logger.info("Pull request creado: #{pr_url}")
end

# --- Workflow principal ---

def main
  issue_number, adw_id = parse_args

  # Generar ADW ID si no se proporciono
  adw_id ||= Adw::Utils.make_adw_id

  # Configurar logger
  logger = Adw::Utils.setup_logger(adw_id, "adw_full_pipeline")
  logger.info("ADW Full Pipeline - ID: #{adw_id}")

  # Paso 1: Ejecutar adw_plan_build (clasificacion + plan + implementacion)
  script_dir = File.dirname(File.expand_path(__FILE__))
  plan_build_script = File.join(script_dir, "adw_plan_build")

  logger.info("Ejecutando adw_plan_build...")
  plan_build_pid = Process.spawn(
    RbConfig.ruby, plan_build_script, issue_number, adw_id,
    out: $stdout,
    err: $stderr
  )
  _, plan_build_status = Process.wait2(plan_build_pid)

  unless plan_build_status.success?
    logger.error("adw_plan_build fallo con codigo #{plan_build_status.exitstatus}")
    exit 1
  end

  logger.info("adw_plan_build completado correctamente")

  # Cargar tracker e issue
  tracker = Adw::Tracker.load(issue_number) || {}
  tracker[:adw_id] = adw_id
  issue = load_issue(issue_number)

  # Paso 2: Fase de testing
  Adw::Tracker.update(tracker, issue_number, "testing", logger)
  logger.info("\n=== Ejecutando suite de tests ===")

  results, passed_count, failed_count = run_tests_with_resolution(adw_id, issue_number, logger, verbose_comments: false)

  log_test_results(issue_number, adw_id, results, passed_count, failed_count, logger)
  logger.info("Resultados de tests: #{passed_count} pasados, #{failed_count} fallidos")

  # Si los tests fallan, parar el pipeline
  if failed_count > 0
    logger.error("Tests fallidos: #{failed_count} fallos pendientes")
    Adw::Tracker.update(tracker, issue_number, "error", logger)
    exit 1
  end

  # Paso 3: Fase de review
  Adw::Tracker.update(tracker, issue_number, "reviewing", logger)
  logger.info("\n=== Ejecutando revision de codigo ===")

  review_result = run_review(adw_id, issue_number, issue, tracker, logger)

  # Si la review tiene hallazgos criticos irresolubles, parar el pipeline
  if review_result[:overall_severity] == "critical" && review_result[:action_required] == "fix_and_rerun"
    logger.error("Review con hallazgos criticos irresolubles")
    Adw::Tracker.update(tracker, issue_number, "error", logger)
    exit 1
  end

  logger.info("Review tecnica completada: severidad #{review_result[:overall_severity]}")

  # Paso 4: Review contra issue + evidencia visual
  Adw::Tracker.update(tracker, issue_number, "reviewing_issue", logger)
  logger.info("\n=== Ejecutando revision contra la issue ===")

  run_issue_review(adw_id, issue_number, issue, tracker, logger)

  # Paso 5: Fase de documentacion
  Adw::Tracker.update(tracker, issue_number, "documenting", logger)
  logger.info("\n=== Ejecutando generacion de documentacion ===")

  run_documentation(adw_id, issue_number, tracker, logger)

  # Paso 6: Commit de todos los cambios
  Adw::Tracker.update(tracker, issue_number, "committing", logger)
  logger.info("\n=== Commiteando cambios ===")

  commit_all_changes(issue, tracker, adw_id, issue_number, logger)

  # Paso 7: Crear pull request
  Adw::Tracker.update(tracker, issue_number, "creating_pr", logger)
  logger.info("\n=== Creando pull request ===")

  create_pull_request(tracker, issue, adw_id, issue_number, logger)

  # Done
  Adw::Tracker.update(tracker, issue_number, "done", logger)
  logger.info("ADW Full Pipeline completado correctamente para issue ##{issue_number}")
end

main
