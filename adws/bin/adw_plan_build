#!/usr/bin/env ruby
# frozen_string_literal: true

#
# ADW Plan & Build - AI Developer Workflow (ADW)
#
# Usage: adw_plan_build <github-issue-number> [adw-id]
#
# Workflow:
# 1. Fetch GitHub issue details
# 2. Classify issue (chore, bug, feature)
# 3. Create feature branch
# 4. Plan Agent: Generate plan in .issues/<id>/plan.md
# 5. Post plan as issue comment (source of truth)
# 6. Build Agent: Implement the solution
# 7. Commit implementation
# 8. Create PR with full context
#

require "bundler/setup"
require_relative "../lib/adw"

include Adw::PipelineHelpers

# Agent name constants
AGENT_PLANNER = "sdlc_planner"
AGENT_IMPLEMENTOR = "sdlc_implementor"
AGENT_CLASSIFIER = "issue_classifier"
AGENT_BRANCH_GENERATOR = "branch_generator"
AGENT_PR_CREATOR = "pr_creator"

def parse_args
  if ARGV.length < 1
    puts "Usage: adw_plan_build <issue-number> [adw-id]"
    puts "Example: adw_plan_build 123"
    puts "Example: adw_plan_build 123 abc12345"
    exit 1
  end

  issue_number = ARGV[0]
  adw_id = ARGV[1]

  [issue_number, adw_id]
end

def classify_issue(issue, issue_number, adw_id, logger)
  request = Adw::AgentTemplateRequest.new(
    agent_name: AGENT_CLASSIFIER,
    slash_command: "/adw:classify_issue",
    args: [issue.to_json],
    issue_number: issue_number,
    adw_id: adw_id,
    model: "sonnet"
  )

  logger.debug("issue_template_request: #{request.to_h}")

  response = Adw::Agent.execute_template(request)

  logger.debug("issue_response: #{response.to_h}")

  unless response.success
    return [nil, response.output]
  end

  issue_command = response.output.strip

  if issue_command == "none"
    return [nil, "No command selected: #{response.output}"]
  end

  unless Adw::ISSUE_CLASS_COMMANDS.include?(issue_command)
    return [nil, "Invalid command selected: #{response.output}"]
  end

  [issue_command, nil]
end

def build_plan(issue, command, plan_path, issue_number, adw_id, logger)
  request = Adw::AgentTemplateRequest.new(
    agent_name: AGENT_PLANNER,
    slash_command: command,
    args: [plan_path, "#{issue.title}: #{issue.body}"],
    issue_number: issue_number,
    adw_id: adw_id,
    model: "opus"
  )

  logger.debug("issue_plan_template_request: #{request.to_h}")

  response = Adw::Agent.execute_template(request)

  logger.debug("issue_plan_response: #{response.to_h}")

  response
end

def implement_plan(plan_file, issue_number, adw_id, logger)
  request = Adw::AgentTemplateRequest.new(
    agent_name: AGENT_IMPLEMENTOR,
    slash_command: "/implement",
    args: [plan_file],
    issue_number: issue_number,
    adw_id: adw_id,
    model: "sonnet"
  )

  logger.debug("implement_template_request: #{request.to_h}")

  response = Adw::Agent.execute_template(request)

  logger.debug("implement_response: #{response.to_h}")

  response
end

def git_branch(issue, issue_class, issue_number, adw_id, logger)
  issue_type = issue_class.delete_prefix("/")

  request = Adw::AgentTemplateRequest.new(
    agent_name: AGENT_BRANCH_GENERATOR,
    slash_command: "/adw:generate_branch_name",
    args: [issue_type, adw_id, issue.to_json],
    issue_number: issue_number,
    adw_id: adw_id,
    model: "sonnet"
  )

  response = Adw::Agent.execute_template(request)

  unless response.success
    return [nil, response.output]
  end

  branch_name = response.output.strip
  logger.info("Created branch: #{branch_name}")
  [branch_name, nil]
end

def git_commit(agent_name, issue, issue_class, issue_number, adw_id, logger)
  issue_type = issue_class.delete_prefix("/")
  unique_agent_name = "#{agent_name}_committer"

  request = Adw::AgentTemplateRequest.new(
    agent_name: unique_agent_name,
    slash_command: "/git:commit",
    args: ["-m", "\"#{agent_name}: #{issue_type}: implement plan for ##{issue.number}\""],
    issue_number: issue_number,
    adw_id: adw_id,
    model: "sonnet"
  )

  response = Adw::Agent.execute_template(request)

  unless response.success
    return [nil, response.output]
  end

  commit_message = response.output.strip
  logger.info("Created commit: #{commit_message}")
  [commit_message, nil]
end

def pull_request(branch_name, issue, issue_number, adw_id, logger)
  request = Adw::AgentTemplateRequest.new(
    agent_name: AGENT_PR_CREATOR,
    slash_command: "/adw:pull_request",
    args: [branch_name, issue.to_json, adw_id],
    issue_number: issue_number,
    adw_id: adw_id,
    model: "sonnet"
  )

  response = Adw::Agent.execute_template(request)

  unless response.success
    return [nil, response.output]
  end

  pr_url = response.output.strip
  logger.info("Created pull request: #{pr_url}")
  [pr_url, nil]
end

def main
  # Parse arguments
  issue_number, adw_id = parse_args

  # Generate ADW ID if not provided
  adw_id ||= Adw::Utils.make_adw_id

  # Set up logger
  logger = Adw::Utils.setup_logger(issue_number, adw_id, "adw_plan_build")
  logger.info("ADW ID: #{adw_id}")

  # Get repo information
  begin
    github_repo_url = Adw::GitHub.repo_url
    repo_path = Adw::GitHub.extract_repo_path(github_repo_url)
  rescue => e
    logger.error("Error getting repository URL: #{e}")
    exit 1
  end

  # Fetch issue
  issue = Adw::GitHub.fetch_issue(issue_number, repo_path)
  logger.debug("issue: #{issue.to_json}")

  # Initialize tracker (load existing or create new)
  tracker = Adw::Tracker.load(issue_number) || {}
  tracker[:adw_id] = adw_id

  # Classify the issue
  Adw::Tracker.update(tracker, issue_number, "classifying", logger)
  issue_command, error = classify_issue(issue, issue_number, adw_id, logger)
  check_error(error, issue_number, "Error classifying issue", logger, tracker)

  logger.info("issue_command: #{issue_command}")
  tracker[:classification] = issue_command

  # Create git branch
  branch_name, error = git_branch(issue, issue_command, issue_number, adw_id, logger)
  check_error(error, issue_number, "Error creating branch", logger, tracker)

  logger.info("Working on branch: #{branch_name}")
  tracker[:branch_name] = branch_name

  # Build the implementation plan
  plan_path = Adw::PipelineHelpers.plan_path_for(issue_number)
  Adw::Tracker.update(tracker, issue_number, "planning", logger)

  issue_plan_response = build_plan(issue, issue_command, plan_path, issue_number, adw_id, logger)
  check_error(issue_plan_response, issue_number, "Error building plan", logger, tracker)

  logger.debug("issue_plan_response.output: #{issue_plan_response.output}")
  logger.info("Plan created at: #{plan_path}")

  # Post plan as separate issue comment (source of truth)
  plan_comment_id = post_plan_comment(issue_number, adw_id, AGENT_PLANNER, plan_path, "Implementation Plan", logger)
  Adw::Tracker.set_phase_comment(tracker, "plan", plan_comment_id)
  Adw::Tracker.save(issue_number, tracker)

  # Implement the plan
  Adw::Tracker.update(tracker, issue_number, "implementing", logger)
  implement_response = implement_plan(plan_path, issue_number, adw_id, logger)
  check_error(implement_response, issue_number, "Error implementing solution", logger, tracker)

  logger.debug("implement_response.output: #{implement_response.output}")

  logger.info("ADW plan & build completed for issue ##{issue_number}. Pending: test, review, document, commit, PR.")
end

main
